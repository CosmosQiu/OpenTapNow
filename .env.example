# Tapnow Online 环境变量配置
# 复制此文件为 .env 并填写实际值
# ========================================

# MySQL 数据库配置
# ----------------------------------------
# 外部 MySQL（默认推荐）：直接填已有数据库连接串
TAPNOW_DATABASE_URL=mysql+pymysql://用户名:密码@127.0.0.1:3306/tapnow_db?charset=utf8mb4

# 内置 MySQL（compose 叠加 docker-compose.mysql.yml）可留空，
# 会自动使用 mysql 容器地址：mysql:3306
# TAPNOW_DATABASE_URL=

# 数据库根密码（仅用于 Docker MySQL 初始化）
MYSQL_ROOT_PASSWORD=change-me-root-password

# MySQL 应用账号密码（docker-compose 会用于 mysql 和 tapnow 服务）
TAPNOW_DB_PASSWORD=change-me-db-password

# 默认管理员账号
# ----------------------------------------
TAPNOW_DEFAULT_ADMIN_USER=admin
TAPNOW_DEFAULT_ADMIN_PASSWORD=please-change-me

# 前端构建时可选覆盖本地服务地址（留空=自动推断）
VITE_LOCAL_SERVER_URL=

# 功能开关
# ----------------------------------------
TAPNOW_ENABLE_FILE_SERVER=true
TAPNOW_ENABLE_PROXY=true
TAPNOW_ENABLE_COMFY=false
TAPNOW_ENABLE_LOG=true
# 日志模式：debug / normal / error
TAPNOW_LOG_MODE=normal

# 静态文件目录（Docker 内使用）
TAPNOW_STATIC_DIR=/app/static

# 数据保存目录
TAPNOW_SAVE_PATH=/app/data
